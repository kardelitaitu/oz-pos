{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "cd ui && npx vite preview --port 4173 --strictPort",
      "url": [
        "http://localhost:4173/#/pos",
        "http://localhost:4173/#/settings",
        "http://localhost:4173/#/products",
        "http://localhost:4173/#/sales-history",
        "http://localhost:4173/#/kds"
      ],
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["accessibility", "best-practices", "seo"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.90 }],
        "categories:best-practices": ["error", { "minScore": 0.80 }],
        "categories:seo": ["error", { "minScore": 0.80 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lhci-reports"
    }
  }
}
