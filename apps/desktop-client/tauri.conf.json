{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OZ-POS",
  "version": "0.0.2",
  "identifier": "com.ozpos.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix ../../ui",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OZ-POS",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "OZ-POS point-of-sale framework",
    "longDescription": "OZ-POS is a modular, extensible point-of-sale framework built on Rust and Tauri v2.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "OZ-POS"
      },
      "wix": {
        "language": "en-US"
      },
      "signCommand": "signtool.exe sign /fd SHA256 /a /tr http://timestamp.digicert.com /td SHA256 %1"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kardelitaitu/oz-pos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5QzJBNzRGMEJBOUQ2QUUKUldTdTFxa0xUNmZDZVkwUGRaRllSbDlJNjZ1VzhJc0ptdExKc29mdVdXNzhGM0RqVElObTFBZFcK",
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
