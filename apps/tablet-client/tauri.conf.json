{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OZ-POS",
  "version": "0.0.17",
  "identifier": "com.ozpos.tablet",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:1420; img-src 'self' data: asset: https://asset.localhost"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "copyright": "Copyright (c) 2024-2026 OZ-POS Contributors. All Rights Reserved.",
    "shortDescription": "OZ-POS tablet POS",
    "longDescription": "OZ-POS tablet-optimised point-of-sale for Android/iOS.",
    "android": {
      "minSdkVersion": 26
    },
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  }
}
