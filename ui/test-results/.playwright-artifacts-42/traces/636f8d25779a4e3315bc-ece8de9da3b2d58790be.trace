: flex;\r\n  gap: var(--space-3);\r\n  align-items: center;\r\n  font-size: var(--text-base);\r\n  color: var(--color-fg-tertiary);\r\n  margin-bottom: var(--space-2);\r\n}\r\n\r\n.sc-detail-notes {\r\n  font-style: italic;\r\n  color: var(--color-fg-tertiary);\r\n  margin: var(--space-2) 0;\r\n}\r\n\r\n.sc-detail-err {\r\n  background: var(--color-danger-bg, #fee2e2);\r\n  color: var(--color-danger, #991b1b);\r\n  padding: var(--space-2_5);\r\n  border-radius: var(--radius-md);\r\n  margin-bottom: var(--space-3);\r\n}\r\n\r\n.sc-detail-success {\r\n  background: var(--color-success-bg, #d1fae5);\r\n  color: var(--color-success, #065f46);\r\n  padding: var(--space-2_5);\r\n  border-radius: var(--radius-md);\r\n  margin-bottom: var(--space-3);\r\n}\r\n\r\n.sc-detail-actions {\r\n  display: flex;\r\n  gap: var(--space-2_5);\r\n  margin-bottom: var(--space-5);\r\n}\r\n\r\n/* Add line */\r\n.sc-detail-add-line {\r\n  padding: var(--space-4);\r\n  margin-bottom: var(--space-5);\r\n}\r\n\r\n.sc-detail-add-line h3 {\r\n  margin: 0 0 var(--space-3);\r\n  font-size: var(--text-md);\r\n}\r\n\r\n.sc-add-line-search input {\r\n  width: 100%;\r\n  padding: var(--space-2) var(--space-3);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n  font-size: var(--text-base);\r\n}\r\n\r\n.sc-add-line-results {\r\n  margin-top: var(--space-2);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n  max-height: 15rem;\r\n  overflow-y: auto;\r\n}\r\n\r\n.sc-add-line-item {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr 3.75rem;\r\n  gap: var(--space-2);\r\n  padding: var(--space-2) var(--space-3);\r\n  cursor: pointer;\r\n  border: none;\r\n  background: none;\r\n  width: 100%;\r\n  text-align: left;\r\n  font-size: var(--text-base);\r\n  border-bottom: 1px solid var(--color-border);\r\n}\r\n\r\n.sc-add-line-item:last-child { border-bottom: none; }\r\n.sc-add-line-item--sel { background: var(--color-accent-dim); }\r\n.sc-add-line-name { font-weight: var(--font-weight-medium); }\r\n.sc-add-line-sku { color: var(--color-fg-tertiary); }\r\n.sc-add-line-stock { text-align: right; }\r\n\r\n.sc-add-line-form {\r\n  margin-top: var(--space-3);\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-3);\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.sc-add-line-selected {\r\n  font-weight: var(--font-weight-medium);\r\n  font-size: var(--text-base);\r\n}\r\n\r\n.sc-add-line-form label {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-1_5);\r\n  font-size: var(--text-base);\r\n}\r\n\r\n.sc-add-line-form input {\r\n  width: 5rem;\r\n  padding: var(--space-1_5) var(--space-2);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n}\r\n\r\n/* Lines table */\r\n.sc-detail-lines {\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-lg);\r\n  overflow: hidden;\r\n}\r\n\r\n.sc-lines-col-sku,\r\n.sc-lines-col-name,\r\n.sc-lines-col-expected,\r\n.sc-lines-col-counted,\r\n.sc-lines-col-diff,\r\n.sc-lines-col-actions {\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sc-lines-header,\r\n.sc-lines-row,\r\n.sc-lines-total {\r\n  display: grid;\r\n  grid-template-columns: 1fr 2fr 5rem 5rem 5rem 2.5rem;\r\n  gap: var(--space-2);\r\n  padding: var(--space-2_5) var(--space-3);\r\n  font-size: var(--text-base);\r\n  align-items: center;\r\n}\r\n\r\n.sc-lines-header {\r\n  background: var(--color-bg-surface);\r\n  font-weight: var(--font-weight-semibold);\r\n  font-size: var(--text-sm);\r\n}\r\n\r\n.sc-lines-row {\r\n  border-bottom: 1px solid var(--color-border);\r\n}\r\n\r\n.sc-lines-total {\r\n  background: var(--color-bg-surface);\r\n  font-weight: var(--font-weight-semibold);\r\n}\r\n\r\n.sc-counted-input {\r\n  width: 4.375rem;\r\n  padding: var(--space-1) var(--space-1_5);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n  font-size: var(--text-base);\r\n}\r\n\r\n.sc-diff-neg { color: var(--color-danger, #dc2626); }\r\n.sc-diff-pos { color: var(--color-success, #16a34a); }\r\n\r\n.sc-remove-btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  min-width: 1.75rem;\r\n  min-height: 1.75rem;\r\n  background: none;\r\n  border: none;\r\n  border-radius: var(--radius-md);\r\n  color: var(--color-danger, #dc2626);\r\n  cursor: pointer;\r\n  font-size: var(--text-lg);\r\n  padding: 0 var(--space-1);\r\n  transition: background var(--duration-100) var(--ease-out);\r\n}\r\n\r\n.sc-remove-btn:hover {\r\n  background: var(--color-danger-bg, rgba(220, 38, 38, 0.1));\r\n}\r\n\r\n.sc-remove-btn:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n}\r\n"],["STYLE",{},".sc-hist-screen {\r\n  max-width: 62.5rem;\r\n  margin: 0 auto;\r\n  padding: var(--space-6);\r\n}\r\n\r\n/* Shared with parent screens */\r\n.sc-title {\r\n  font-size: var(--text-2xl);\r\n  font-weight: var(--font-weight-semibold);\r\n  margin: 0;\r\n}\r\n\r\n.sc-badge {\r\n  display: inline-block;\r\n  padding: var(--space-0_5) var(--space-2);\r\n  border-radius: var(--radius-md);\r\n  font-size: var(--text-sm);\r\n  font-weight: var(--font-weight-medium);\r\n}\r\n\r\n.sc-diff-neg { color: var(--color-danger, #dc2626); }\r\n.sc-diff-pos { color: var(--color-success, #16a34a); }\r\n\r\n.sc-hist-header {\r\n  margin-bottom: var(--space-5);\r\n}\r\n\r\n.sc-hist-empty {\r\n  text-align: center;\r\n  color: var(--color-fg-tertiary);\r\n  padding: var(--space-10) 0;\r\n}\r\n\r\n.sc-hist-layout {\r\n  display: grid;\r\n  grid-template-columns: 18.75rem 1fr;\r\n  gap: var(--space-5);\r\n}\r\n\r\n.sc-hist-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-2);\r\n}\r\n\r\n.sc-hist-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-1);\r\n  padding: var(--space-3);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(