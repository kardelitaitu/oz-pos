 column;\r\n  gap: var(--space-4);\r\n}\r\n\r\n.stock-transfers-loading-skeleton .stock-transfers-header {\r\n  margin-bottom: 0;\r\n}\r\n\r\n.stock-transfers-loading-skeleton .stock-transfers-filters {\r\n  margin-bottom: 0;\r\n}\r\n\r\n.stock-transfers-loading-skeleton .stock-transfers-table thead {\r\n  pointer-events: none;\r\n}\r\n\r\n.stock-transfers-empty {\r\n  padding: var(--space-12) var(--space-4);\r\n  text-align: center;\r\n  color: var(--color-fg-secondary);\r\n}\r\n\r\n.stock-transfers-error-text {\r\n  margin-bottom: var(--space-3);\r\n}\r\n\r\n/* ── Filters ─────────────────────────────────────────────────── */\r\n\r\n.stock-transfers-filters {\r\n  display: flex;\r\n  gap: var(--space-2);\r\n  margin-bottom: var(--space-4);\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.stock-transfers-filter-btn {\r\n  background: var(--color-bg-surface);\r\n  border: 1px solid var(--color-border);\r\n  padding: var(--space-1) var(--space-3);\r\n  border-radius: var(--radius-full);\r\n  font-size: var(--text-sm);\r\n  cursor: pointer;\r\n  color: var(--color-fg-secondary);\r\n  transition: all var(--duration-150) var(--ease-out);\r\n}\r\n\r\n.stock-transfers-filter-btn:hover {\r\n  background: var(--color-bg);\r\n  border-color: var(--color-accent);\r\n}\r\n\r\n.stock-transfers-filter-btn:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n}\r\n\r\n.stock-transfers-filter-btn.active {\r\n  background: var(--color-accent);\r\n  color: var(--color-accent-fg);\r\n  border-color: var(--color-accent);\r\n}\r\n\r\n/* ── Table ──────────────────────────────────────────────────────── */\r\n\r\n.stock-transfers-table-wrap {\r\n  overflow-x: auto;\r\n}\r\n\r\n.stock-transfers-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  font-size: var(--text-sm);\r\n}\r\n\r\n.stock-transfers-table th {\r\n  text-align: left;\r\n  padding: var(--space-2) var(--space-3);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--color-fg-secondary);\r\n  border-bottom: 2px solid var(--color-border);\r\n  white-space: nowrap;\r\n}\r\n\r\n.stock-transfers-table td {\r\n  padding: var(--space-3) var(--space-3);\r\n  border-bottom: 1px solid var(--color-border);\r\n  vertical-align: middle;\r\n}\r\n\r\n.stock-transfers-cell-number {\r\n  font-family: var(--font-mono);\r\n  font-size: var(--text-xs);\r\n}\r\n\r\n.stock-transfers-link {\r\n  background: none;\r\n  border: none;\r\n  color: var(--color-accent);\r\n  cursor: pointer;\r\n  font-family: var(--font-mono);\r\n  font-size: var(--text-xs);\r\n  padding: 0;\r\n  text-decoration: none;\r\n}\r\n\r\n.stock-transfers-link:hover {\r\n  text-decoration: underline;\r\n}\r\n\r\n.stock-transfers-link:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n  border-radius: var(--radius-sm);\r\n}\r\n\r\n.stock-transfers-cell-date {\r\n  white-space: nowrap;\r\n  color: var(--color-fg-tertiary);\r\n  font-size: var(--text-xs);\r\n}\r\n\r\n.stock-transfers-cell-actions {\r\n  display: flex;\r\n  gap: var(--space-2);\r\n}\r\n\r\n.stock-transfers-action-btn {\r\n  background: none;\r\n  border: 1px solid var(--color-border);\r\n  padding: var(--space-1) var(--space-2);\r\n  border-radius: var(--radius-md);\r\n  font-size: var(--text-xs);\r\n  cursor: pointer;\r\n  color: var(--color-fg-secondary);\r\n  transition: all var(--duration-150) var(--ease-out);\r\n}\r\n\r\n.stock-transfers-action-btn:hover {\r\n  background: var(--color-bg-surface);\r\n}\r\n\r\n.stock-transfers-action-btn:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n}\r\n\r\n.stock-transfers-action-btn--danger {\r\n  color: var(--color-danger);\r\n  border-color: var(--color-danger-dim);\r\n}\r\n\r\n.stock-transfers-action-btn--danger:hover {\r\n  background: var(--color-danger-bg);\r\n}\r\n\r\n/* ── Badge ──────────────────────────────────────────────────────── */\r\n\r\n.stock-transfers-badge {\r\n  display: inline-block;\r\n  padding: var(--space-0_5) var(--space-2);\r\n  border-radius: var(--radius-full);\r\n  font-size: var(--text-xs);\r\n  font-weight: var(--font-weight-semibold);\r\n  white-space: nowrap;\r\n}\r\n\r\n.stock-transfers-badge--draft {\r\n  background: var(--color-bg-surface);\r\n  color: var(--color-fg-tertiary);\r\n  border: 1px solid var(--color-border);\r\n}\r\n\r\n.stock-transfers-badge--pending {\r\n  background: var(--color-warning-bg);\r\n  color: var(--color-fg);\r\n}\r\n\r\n.stock-transfers-badge--in_transit {\r\n  background: var(--color-info-bg);\r\n  color: var(--color-fg);\r\n}\r\n\r\n.stock-transfers-badge--received {\r\n  background: var(--color-success-bg);\r\n  color: var(--color-fg);\r\n}\r\n\r\n.stock-transfers-badge--cancelled {\r\n  background: var(--color-danger-bg);\r\n  color: var(--color-fg);\r\n}\r\n\r\n/* ── Overlay / Modal ─────────────────────────────────────────── */\r\n\r\n.stock-transfers-overlay {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: var(--z-modal);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: var(--color-bg-overlay);\r\n  backdrop-filter: blur(3px);\r\n  -webkit-backdrop-filter: blur(3px);\r\n  will-change: backdrop-filter;\r\n  padding: var(--space-4);\r\n}\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  .stock-transfers-overlay {\r\n    animation: stock-overlay-fade-in var(--duration-200) var(--ease-out);\r\n  }\r\n\r\n  @keyframes stock-overlay-fade-in {\r\n    from { opacity: 0; }\r\n    to   { opacity: 1; }\r\n  }\r\n\r\n  .stock-transfers-modal {\r\n    animation: stock-modal-in var(--duration-200) var(--ease-out) both;\r\n  }\r\n\r\n  @keyframes stock-modal-in {\r\n    from { opacity: 0; transform: translateY(0.5rem); }\r\n    to   { opacity: 1; transform: translateY(0); }\r\n  }\r\n}\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  /* Exit: mirror of entry keyframes */\r\n  @keyframes stock-overlay-fade-out {\r\n    from { opacity: 1; }\r\n    to   { opacity: 0; }\r\n  }\r\n\r\n  @keyframes stock-modal-out {\r\n    from { opacity: 1; transform: translateY(0); }\r\n    to   { opacity: 0; transform: translateY(0.5rem); }\r\n  }\r\n\r\n  .stock-transfers-overlay--exiting {\r\n    animation: stock-overlay-fade-out var(--duration-200) var(--ease-out) both;\r\n    pointer-events: none;\r\n  }\r\n\r\n  .stock-transfers-modal--exiting {\r\n    animation: stock-modal-out var(--duration-200) var(--ease-out) both;\r\n  }\r\n}\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n  .stock-transfers-overlay {\r\n    backdrop-filter: none;\r\n    -webkit-backdrop-filter: none;\r\n    will-change: auto;\r\n  }\r\n}\r\n\r\n.stock-transfers-modal {\r\n  position: relative;\r\n  background: var(--color-bg-elevated);\r\n  border-radius: var(--radius-xl);\r\n  box-shadow: var(--shadow-xl);\r\n  max-height: 90vh;\r\n  overflow-y: auto;\r\n  width: 100%;\r\n  max-width: 30rem;\r\n}\r\n\r\n.stock-transfers-modal--wide {\r\n  max-width: 45rem;\r\n}\r\n\r\n.stock-transfers-modal-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  padding: var(--space-4) var(--space-5);\r\n  border-bottom: 1px solid var(--color-border);\r\n}\r\n\r\n.stock-transfers-modal-header h2 {\r\n  margin: 0;\r\n  font-size: var(--text-lg);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--color-fg);\r\n}\r\n\r\n.stock-transfers-modal-close {\r\n  background: none;\r\n  border: none;\r\n  font-size: var(--text-xl);\r\n  color: var(--color-fg-tertiary);\r\n  cursor: pointer;\r\n  padding: 0;\r\n  line-height: 1;\r\n}\r\n\r\n.stock-transfers-modal-close:hover {\r\n  color: var(--color-fg);\r\n}\r\n\r\n.stock-transfers-modal-close:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n  border-radius: var(--radius-sm);\r\n}\r\n\r\n.stock-transfers-modal-body {\r\n  padding: var(--space-4) var(--space-5);\r\n}\r\n\r\n.stock-transfers-modal-actions {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: var(--space-2);\r\n  padding: var(--space-3) var(--space-5);\r\n  border-top: 1px solid var(--color-border);\r\n}\r\n\r\n/* ── Detail ──────────────────────────────────────────────────────── */\r\n\r\n.stock-transfers-detail {\r\n  padding: var(--space-3) 0;\r\n}\r\n\r\n.stock-transfers-detail-info {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: var(--space-3);\r\n  margin-bottom: var(--space-4);\r\n}\r\n\r\n.stock-transfers-detail-field {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-1);\r\n}\r\n\r\n.stock-transfers-detail-label {\r\n  font-size: var(--text-xs);\r\n  font-weight: var(--font-weight-medium);\r\n  color: var(--color-fg-secondary);\r\n}\r\n\r\n.stock-transfers-detail-actions {\r\n  display: flex;\r\n  gap: var(--space-2);\r\n  margin-top: var(--space-4);\r\n  flex-wrap: wrap;\r\n}\r\n\r\n/* ── Detail skeleton ─────────────────────────────────────────────────── */\r\n.stock-transfers-detail-skeleton {\r\n  pointer-events: none;\r\n}\r\n\r\n.stock-transfers-detail-skeleton .stock-transfers-lines-table thead {\r\n  pointer-events: none;\r\n}\r\n\r\n.stock-transfers-detail-skeleton .stock-transfers-lines-table tbody tr td {\r\n  border-bottom: none;\r\n}\r\n\r\n/* ── Lines table (in detail) ─────────────────────────────────── */\r\n\r\n.stock-transfers-lines-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  font-size: var(--text-sm);\r\n  margin-bottom: var(--space-3);\r\n}\r\n\r\n.stock-transfers-lines-table th {\r\n  text-align: left;\r\n  padding: var(--space-2) var(--space-2);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--color-fg-secondary);\r\n  border-bottom: 1px solid var(--color-border);\r\n  font-size: var(--text-xs);\r\n}\r\n\r\n.stock-transfers-lines-table td {\r\n  padding: var(--space-2);\r\n  border-bottom: 1px solid var(--color-border);\r\n}\r\n\r\n/* ── Create form ─────────────────────────────────────────────────── */\r\n\r\n.stock-transfers-form-row {\r\n  display: flex;\r\n  gap: var(--space-3);\r\n  margin-bottom: var(--space-3);\r\n}\r\n\r\n.stock-transfers-form-row .stock-transfers-field {\r\n  flex: 1;\r\n}\r\n\r\n.stock-transfers-field {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-1);\r\n  margin-bottom: var(--space-3);\r\n}\r\n\r\n.stock-transfers-label {\r\n  font-size: var(--text-xs);\r\n  font-weight: var(--font-weight-medium);\r\n  color: var(--color-fg-secondary);\r\n}\r\n\r\n.stock-transfers-input {\r\n  padding: var(--space-2) var(--space-3);\r\n  font-size: var(--text-sm);\r\n  color: var(--color-fg);\r\n  background: var(--color-bg-surface);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n  box-sizing: border-box;\r\n  width: 100%;\r\n}\r\n\r\n.stock-transfers-input:focus-visible {\r\n  outline: none;\r\n  border-color: var(--color-border-focus);\r\n  box-shadow: inset 0 0 0 0.1875rem var(--color-accent-subtle);\r\n}\r\n\r\n.stock-transfers-textarea {\r\n  resize: vertical;\r\n  min-height: 3rem;\r\n}\r\n\r\n/* ── Lines section ──────────────────────────────────────────────── */\r\n\r\n.stock-transfers-lines-section {\r\n  margin-top: var(--space-3);\r\n  padding-top: var(--space-3);\r\n  border-top: 1px solid var(--color-border);\r\n}\r\n\r\n.stock-transfers-lines-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--space-2);\r\n}\r\n\r\n.stock-transfers-line-row {\r\n  display: flex;\r\n  gap: var(--space-2);\r\n  align-items: center;\r\n  margin-bottom: var(--space-2);\r\n}\r\n\r\n.stock-transfers-line-sku {\r\n  flex: 2;\r\n}\r\n\r\n.stock-transfers-line-name {\r\n  flex: 3;\r\n}\r\n\r\n.stock-transfers-line-qty {\r\n  flex: 1;\r\n  min-width: 3.75rem;\r\n}\r\n\r\n.stock-transfers-line-remove {\r\n  background: none;\r\n  border: none;\r\n  font-size: var(--text-lg);\r\n  color: var(--color-danger);\r\n  cursor: pointer;\r\n  padding: var(--space-1);\r\n  line-height: 1;\r\n}\r\n\r\n.stock-transfers-line-remove:hover {\r\n  opacity: 0.8;\r\n}\r\n\r\n.stock-transfers-line-remove:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n  border-radius: var(--radius-sm);\r\n}\r\n\r\n/* ── Error ────────────────────────────────────────────────────────── */\r\n\r\n.stock-transfers-error {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-2);\r\n  padding: var(--space-2) var(--space-3);\r\n  background: var(--color-danger-bg);\r\n  border: 1px solid var(--color-danger-dim);\r\n  border-radius: var(--radius-md);\r\n  color: var(--color-danger);\r\n  font-size: var(--text-sm);\r\n  font-weight: var(--font-weight-medium);\r\n  margin-top: var(--space-3);\r\n}\r\n"],["STYLE",{},"/* ── Canvas Chart Container ─────────────────────────────────────────── */\n\n.canvas-chart-container {\n  position: relative;\n  width: 100%;\n  overflow: hidden;\n}\n\n.canvas-chart {\n  display: block;\n  width: 100%;\n  height: 100%;\n}\n\n/* ── Chart card wrapper (used on dashboard) ─────────────────────────── */\n\n.chart-card {\n  padding: var(--space-3);\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n}\n\n.chart-card-title {\n  margin: 0 0 var(--space-2);\n  font-size: var(--text-xs);\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: var(--color-fg-secondary);\n}\n\n.chart-card-body {\n  flex: 1;\n  min-height: 0;\n}\n\n/* ── Comparison / period indicator ──────────────────────────────────── */\n\n.comparison-delta {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--space-0_5);\n  font-size: var(--text-sm);\n  font-weight: 600;\n  font-variant-numeric: tabular-nums;\n}\n\n.comparison-delta--positive {\n  color: var(--color-success, #10b981);\n}\n\n.comparison-delta--negative {\n  color: var(--color-danger, #ef4444);\n}\n\n.comparison-delta--neutral {\n  color: var(--color-fg-tertiary, #9ca3af);\n}\n"],["STYLE",{},"/* ============================================================\r\n * OZ-POS CSS Reset\r\n *\r\n * Builds on the standard box-sizing + margin reset with\r\n * POS-specific defaults: larger tap targets, system-like\r\n * button appearance, and accessible focus rings.\r\n * ============================================================ */\r\n\r\n*,\r\n*::before,\r\n*::after {\r\n  box-sizing: border-box;\r\n  margin: 0;\r\n  padding: 0;\r\n}\r\n\r\nhtml {\r\n  font-size: 16px; /* root rem base — intentional, not a token target */\r\n  -webkit-text-size-adjust: 100%;\r\n  -moz-text-size-adjust: 100%;\r\n  text-size-adjust: 100%;\r\n  line-height: var(--leading-normal, 1.5);\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n  text-rendering: optimizeLegibility;\r\n}\r\n\r\nhtml[data-font-smoothing=\"subpixel\"] {\r\n  -webkit-font-smoothing: subpixel-antialiased;\r\n  -moz-osx-font-smoothing: auto;\r\n}\r\n\r\nbody {\r\n  font-family: var(--font-sans, system-ui, -apple-system, sans-serif);\r\n  font-size: var(--text-base);\r\n  font-weight: var(--font-weight-normal, 400);\r\n  line-height: var(--leading-normal, 1.5);\r\n  color: var(--color-fg, #1a1a1a);\r\n  background: var(--color-bg, #ffffff);\r\n  min-height: 100dvh;\r\n  overflow-x: hidden;\r\n}\r\n\r\nimg,\r\nsvg,\r\nvideo,\r\ncanvas {\r\n  display: block;\r\n  max-width: 100%;\r\n  height: auto;\r\n}\r\n\r\na {\r\n  color: var(--color-link, #059669);\r\n  text-decoration: none;\r\n}\r\na:hover {\r\n  color: var(--color-link-hover, #047857);\r\n  text-decoration: underline;\r\n}\r\n\r\n/* ── Buttons ───────────────────────────────────── */\r\nbutton {\r\n  font-family: inherit;\r\n  font-size: inherit;\r\n  font-weight: var(--font-weight-medium, 500);\r\n  line-height: inherit;\r\n  cursor: pointer;\r\n  appearance: none;\r\n  border: none;\r\n  background: none;\r\n  color: inherit;\r\n  padding: 0;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--space-2, 0.5rem);\r\n  user-select: none;\r\n  -webkit-user-select: none;\r\n  touch-action: manipulation;\r\n}\r\n\r\nbutton:disabled {\r\n  cursor: not-allowed;\r\n  opacity: 0.5;\r\n}\r\n\r\n/* ── Inputs ────────────────────────────────────── */\r\ninput,\r\nselect,\r\ntextarea {\r\n  font-family: inherit;\r\n  font-size: inherit;\r\n  line-height: inherit;\r\n  color: var(--color-fg, #1a1a1a);\r\n  background: var(--color-bg-input, #ffffff);\r\n  border: 1px solid var(--color-border, #e5e5e5);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem);\r\n  outline: none;\r\n  transition: border-color var(--duration-150, 150ms) var(--ease-out),\r\n    box-shadow var(--duration-150, 150ms) var(--ease-out);\r\n}\r\n\r\ninput:focus-visible,\r\nselect:focus-visible,\r\ntextarea:focus-visible {\r\n  outline: none;\r\n  border-color: var(--color-border-focus, #10b981);\r\n  box-shadow: 0 0 0 3px var(--color-accent-subtle, #d1fae5);\r\n}\r\n\r\n/* ── Focus ring (keyboard only) ────────────────── */\r\n:focus-visible {\r\n  outline: 2px solid var(--color-border-focus, #10b981);\r\n  outline-offset: 2px;\r\n}\r\n\r\n:focus-visible:not(:focus-visible) {\r\n  outline: none;\r\n}\r\n\r\n/* ── Lists ─────────────────────────────────────── */\r\nul, ol {\r\n  list-style: none;\r\n}\r\n\r\n/* ── Tables ────────────────────────────────────── */\r\ntable {\r\n  border-collapse: collapse;\r\n  width: 100%;\r\n}\r\n\r\n/* ── Headings ──────────────────────────────────── */\r\nh1, h2, h3, h4, h5, h6 {\r\n  font-weight: var(--font-weight-semibold, 600);\r\n  line-height: var(--leading-tight, 1.25);\r\n  overflow-wrap: break-word;\r\n}\r\n\r\nh1 { font-size: var(--text-2xl, 1.5rem); }\r\nh2 { font-size: var(--text-xl, 1.25rem); }\r\nh3 { font-size: var(--text-lg); }\r\n\r\n/* ── Code / pre ────────────────────────────────── */\r\ncode,\r\npre {\r\n  font-family: var(--font-mono);\r\n  font-size: 0.9em; /* relative em unit — no --text-* token equivalent */\r\n}\r\n\r\npre {\r\n  background: var(--color-bg-surface, #f5f5f5);\r\n  border: 1px solid var(--color-border, #e5e5e5);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--space-4, 1rem);\r\n  overflow-x: auto;\r\n}\r\n\r\n/* ── Scrollbar (Webkit) ────────────────────────── */\r\n::-webkit-scrollbar {\r\n  width: 8px;\r\n  height: 8px;\r\n}\r\n::-webkit-scrollbar-track {\r\n  background: transparent;\r\n}\r\n::-webkit-scrollbar-thumb {\r\n  background: var(--neutral-300, #d4d4d4);\r\n  border-radius: var(--radius-full, 9999px);\r\n}\r\n::-webkit-scrollbar-thumb:hover {\r\n  background: var(--neutral-400, #a3a3a3);\r\n}\r\n\r\n/* ── Selection ─────────────────────────────────── */\r\n::selection {\r\n  background: var(--color-accent, #10b981);\r\n  color: var(--color-fg-inverse, #ffffff);\r\n}\r\n\r\n/* ── Reduced motion ────────────────────────────── */\r\n@media (prefers-reduced-motion: reduce) {\r\n  *,\r\n  *::before,\r\n  *::after {\r\n    animation-duration: 0.01ms !important;\r\n    animation-iteration-count: 1 !important;\r\n    transition-duration: 0.01ms !important;\r\n    scroll-behavior: auto !important;\r\n  }\r\n}\r\n"],["STYLE",{},"/* ============================================================\r\n * OZ-POS Design Tokens\r\n *\r\n * A single source of truth for every visual property in the UI.\r\n * Components must NEVER hardcode colours, sizes, or shadows.\r\n * Reference tokens via `var(--token-name)` exclusively.\r\n *\r\n * TOKEN NAMING CONVENTION\r\n *   --category-property[-variant]\r\n *   e.g. --color-bg-elevated, --space-4, --font-size-lg\r\n *\r\n * THEMES\r\n *   Default (:root) is Steel Blue Glassmorphism (Dark)\r\n *   [data-theme=\"light\"] is Steel Blue Elevated (Light)\r\n *   [data-theme=\"dark\"] is Steel Blue Solid (Dark)\r\n *   ============================================================ */\r\n\r\n/* ── Default Theme (Steel Blue Glassmorphism) ──────────────────── */\r\n:root {\r\n  /* ── Font ─────────────────────────────────────── */\r\n  --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont,\r\n    'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;\r\n  --font-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono',\r\n    'Cascadia Code', Consolas, monospace;\r\n\r\n  /* ── Type scale (modular scale 1.25) ───────────── */\r\n  --text-2xs:  0.5625rem; /* 9px — badges, fine print */\r\n  --text-xs:   0.625rem;  /* 10px */\r\n  --text-sm:   0.75rem;   /* 12px */\r\n  --text-base: 0.875rem;  /* 14px */\r\n  --text-md:   1rem;      /* 16px */\r\n  --text-lg:   1.125rem;  /* 18px */\r\n  --text-xl:   1.25rem;   /* 20px */\r\n  --text-2xl:  1.5rem;    /* 24px */\r\n  --text-3xl:  1.875rem;  /* 30px */\r\n  --text-4xl:  2.25rem;   /* 36px */\r\n  --text-hero: 4rem;      /* 64px — kiosk hero title */\r\n\r\n  --font-weight-normal:   400;\r\n  --font-weight-medium:   500;\r\n  --font-weight-semibold: 600;\r\n  --font-weight-bold:     700;\r\n\r\n  --leading-tight:   1.25;\r\n  --leading-normal:  1.5;\r\n  --leading-relaxed: 1.625;\r\n\r\n  --tracking-tight:  -0.01em;\r\n  --tracking-normal: 0;\r\n  --tracking-wide:   0.02em;\r\n\r\n  /* ── Colour palette ────────────────────────────── */\r\n  /* Neutral (Dark Navy Tint) */\r\n  --neutral-50:  #0d0d14;\r\n  --neutral-100: #13131c;\r\n  --neutral-200: #1a1a2e;\r\n  --neutral-300: #2a2a40;\r\n  --neutral-400: #475569;\r\n  --neutral-500: #64748b;\r\n  --neutral-600: #94a3b8;\r\n  --neutral-700: #cbd5e1;\r\n  --neutral-800: #e2e8f0;\r\n  --neutral-900: #f1f5f9;\r\n  --neutral-950: #ffffff;\r\n\r\n  /* Brand / Primary — Steel Blue (matches light theme) */\r\n  --primary-50:  #f0f5fa;\r\n  --primary-100: #dbeafe;\r\n  --primary-200: #bfdbfe;\r\n  --primary-300: #93c5fd;\r\n  --primary-400: #5a9fd4;\r\n  --primary-500: #2b5c8f;\r\n  --primary-600: #224b75;\r\n  --primary-700: #1a3a5c;\r\n  --primary-800: #122945;\r\n  --primary-900: #0b1a2e;\r\n  --primary-950: #060d17;\r\n\r\n  /* Semantic */\r\n  --success-500: #22c55e;\r\n  --warning-500: #f59e0b;\r\n  --danger-50:   #450a0a;\r\n  --danger-100:  #7f1d1d;\r\n  --danger-200:  #991b1b;\r\n  --danger-500:  #ef4444;\r\n  --danger-600:  #dc2626;\r\n  --danger-700:  #b91c1c;\r\n  --danger-800:  #991b1b;\r\n  --info-500:    #3b82f6;\r\n\r\n  /* ── Semantic colour tokens (Steel Blue Glassmorphism) ────────────── */\r\n  /* Radial bloom — extra colour stops for 8-bit GPU banding reduction */\r\n  --color-bg: radial-gradient(ellipse at 50% -10%,\r\n    #132540 0%,\r\n    #111f33 15%,\r\n    #0e1a2b 28%,\r\n    #0c1523 40%,\r\n    #09111d 52%,\r\n    #070e19 65%,\r\n    #060c16 78%,\r\n    #040a12 100%);\r\n  /* Blue-tinted glass surfaces — hue resonance with the background */\r\n  --color-bg-elevated:     rgba(16, 82, 188, 0.08);\r\n  --color-bg-surface:      rgba(16, 82, 188, 0.05);\r\n  --color-bg-overlay:      rgba(0, 0, 0, 0.55);\r\n  --color-bg-input:        rgba(0, 0, 0, 0.25);\r\n\r\n  --color-fg:              #f0f6ff;\r\n  --color-fg-primary:      #ffffff;\r\n  --color-fg-secondary:    #a8c4e0;\r\n  --color-fg-tertiary:     #6b92b4;\r\n  --color-fg-disabled:     #6b92b4;\r\n  --color-fg-inverse:      #07111d;\r\n\r\n  /* Luminous accent — lighter steel blue pops on dark backgrounds */\r\n  --color-accent:          #5a9fd4;\r\n  --color-accent-hover:    #73b2e0;\r\n  --color-accent-active:   #3d88c4;\r\n  --color-accent-subtle:   rgba(16, 82, 188, 0.18);\r\n  --color-accent-fg:       #07111d;\r\n  --color-accent-hover-fg: #07111d;\r\n  --color-accent-active-fg:#07111d;\r\n  --color-accent-subtle-fg:#f0f6ff;\r\n\r\n  /* Blue-tinted borders for hue resonance */\r\n  --color-border:          rgba(90, 159, 212, 0.12);\r\n  --color-border-hover:    rgba(90, 159, 212, 0.25);\r\n  --color-border-strong:   rgba(90, 159, 212, 0.35);\r\n  --color-border-focus:    #5a9fd4;\r\n  --color-border-subtle:   rgba(16, 82, 188, 0.06);\r\n\r\n  --color-success:         #4ade80;\r\n  --color-success-bg:      rgba(74, 222, 128, 0.08);\r\n  --color-success-dim:     #86efac;\r\n  --color-warning:         #fbbf24;\r\n  --color-warning-bg:      rgba(251, 191, 36, 0.08);\r\n  --color-danger:          #dc2626;\r\n  --color-danger-hover:    #b91c1c;\r\n  --color-danger-700:      #991b1b;\r\n  --color-danger-bg:       rgba(220, 38, 38, 0.12);\r\n  --color-danger-dim:      #fca5a5;\r\n  --color-danger-fg:       #ffffff;\r\n  --color-info:            #60a5fa;\r\n  --color-info-bg:         rgba(96, 165, 250, 0.08);\r\n\r\n  --color-link:            #73b2e0;\r\n  --color-link-hover:      #93c5fd;\r\n  --color-link-visited:    #a78bfa;\r\n\r\n  --color-bg-primary:      var(--neutral-50);\r\n  --color-bg-secondary:    var(--neutral-100);\r\n  --color-bg-hover:        rgba(90, 159, 212, 0.1);\r\n\r\n  --color-accent-dim:      rgba(90, 159, 212, 0.12);\r\n  --color-accent-alpha:    rgba(90, 159, 212, 0.2);\r\n  --color-accent-secondary: #5a9fd4;\r\n\r\n  /* Glassmorphism Controls */\r\n  --blur-amount: 20px;\r\n  /* Blue-tinted glow shadow for hue-resonant depth */\r\n  --shadow-glow: 0 8px 32px rgba(4, 10, 18, 0.7), inset 0 1px 0 rgba(90, 159, 212, 0.15);\r\n\r\n  /* ── Spacing scale (rem) ───────────────────────── */\r\n  --space-0:   0;\r\n  --space-0_5: 0.125rem;\r\n  --space-1:   0.25rem;\r\n  --space-1_5: 0.375rem;\r\n  --space-2:   0.5rem;\r\n  --space-2_5: 0.625rem;\r\n  --space-3:   0.75rem;\r\n  --space-3_5: 0.875rem;\r\n  --space-4:   1rem;\r\n  --space-5:   1.25rem;\r\n  --space-6:   1.5rem;\r\n  --space-7:   1.75rem;\r\n  --space-8:   2rem;\r\n  --space-9:   2.25rem;\r\n  --space-10:  2.5rem;\r\n  --space-11:  2.75rem;\r\n  --space-12:  3rem;\r\n  --space-14:  3.5rem;\r\n  --space-16:  4rem;\r\n  --space-20:  5rem;\r\n  --space-24:  6rem;\r\n  --space-minus-1: calc(-1 * var(--space-1));  /* -0.25rem — negative spacing utility */\r\n\r\n  /* ── Border radius ─────────────────────────────── */\r\n  --radius-none: 0;\r\n  --radius-sm:   0.125rem;\r\n  --radius-md:   0.375rem;\r\n  --radius-lg:   0.5rem;\r\n  --radius-xl:   0.75rem;\r\n  --radius-2xl:  1rem;\r\n  --radius-3xl:  1.5rem;\r\n  --radius-full: 9999px;\r\n  --radius-xl-2:  0.625rem;  /* 10px — between radius-lg (8px) and radius-xl (12px) */\r\n\r\n  /* ── Single shadow size (8px) across all levels ─ */\r\n  /* Normal elevation curve: smallest elements get lightest shadow */\r\n  --shadow-xs:   0 0 12px rgba(4,10,18,0.00);\r\n  --shadow-sm:   0 0 12px rgba(4,10,18,0.08);\r\n  --shadow-md:   0 0 12px rgba(4,10,18,0.16);\r\n  --shadow-lg:   0 0 12px rgba(4,10,18,0.24);\r\n  --shadow-xl:   0 0 12px rgba(4,10,18,0.32);\r\n  --shadow-2xl:  0 0 12px rgba(4,10,18,0.40);\r\n  --shadow-inner: inset 0 2px 4px rgba(4, 10, 18, 0.20);\r\n  /* Status-glow shadows — used by ConnectionStatus and status indicators */\r\n  --shadow-glow-success: 0 0 8px rgba(16, 185, 129, 0.4);\r\n  --shadow-glow-warning: 0 0 8px rgba(245, 158, 11, 0.4);\r\n  --shadow-glow-danger:  0 0 8px rgba(239, 68, 68, 0.4);\r\n  /* QR scan expanding-ring start state (green glow at 30%) */\r\n  --shadow-pulse: 0 0 0 0 color-mix(in srgb, var(--color-success) 30%, transparent);\r\n\r\n  /* ── Timing / transitions ──────────────────────── */\r\n  --duration-0:    0ms;\r\n  --duration-75:   75ms;\r\n  --duration-100:  100ms;\r\n  --duration-150:  150ms;\r\n  --duration-200:  200ms;\r\n  --duration-300:  300ms;\r\n  --duration-400:  400ms;\r\n  --duration-500:  500ms;\r\n  --duration-600:  600ms;\r\n  --duration-800:  800ms;\r\n  --duration-1000: 1000ms;\r\n  --duration-1200: 1200ms;\r\n  --duration-1500: 1500ms;\r\n  --duration-2000: 2000ms;\r\n  --duration-2500: 2500ms;\r\n  --duration-3000: 3000ms;\r\n  --duration-3500: 3500ms;\r\n  --duration-4000: 4000ms;\r\n  --ease-in:       cubic-bezier(0.4, 0, 1, 1);\r\n  --ease-out:      cubic-bezier(0, 0, 0.2, 1);\r\n  --ease-in-out:   cubic-bezier(0.4, 0, 0.2, 1);\r\n  --ease-linear:   linear;\r\n\r\n  /* ── Breakpoints ──────────────────────────────────── */\r\n  --bp-desktop: 1024px;\r\n  --bp-tablet: 1023px;\r\n  --bp-tablet-portrait: 768px;\r\n  --bp-mobile: 480px;\r\n\r\n  /* ── Touch targets (WCAG 2.1 AA: ≥ 44px) ────────────── */\r\n  --touch-target-min: 44px;\r\n  --touch-target-comfortable: 48px;\r\n\r\n  /* ── Z-index layers ────────────────────────────── */\r\n  --z-base:      0;\r\n  --z-dropdown:  100;\r\n  --z-sticky:    200;\r\n  --z-overlay:   300;\r\n  --z-modal:     400;\r\n  --z-toast:     500;\r\n  --z-tooltip:   600;\r\n}\r\n\r\n/* ── Light mode (Steel Blue Elevated) ────────────────────────────── */\r\n[data-theme='light'] {\r\n  --blur-amount: 0px;\r\n  --shadow-glow: none;\r\n\r\n  /* Neutral — Tailwind slate (industry standard) */\r\n  --neutral-50:  #f8fafc;\r\n  --neutral-100: #f1f5f9;\r\n  --neutral-200: #e2e8f0;\r\n  --neutral-300: #cbd5e1;\r\n  --neutral-400: #94a3b8;\r\n  --neutral-500: #64748b;\r\n  --neutral-600: #475569;\r\n  --neutral-700: #334155;\r\n  --neutral-800: #1e293b;\r\n  --neutral-900: #0f172a;\r\n  --neutral-950: #020617;\r\n\r\n  /* Brand / Primary — Steel Blue */\r\n  --primary-50:  #f3f6fc;\r\n  --primary-100: #e2eaf7;\r\n  --primary-200: #c3d4ee;\r\n  --primary-300: #9fbae4;\r\n  --primary-400: #749bd8;\r\n  --primary-500: #1052bc;\r\n  --primary-600: #0d439a;\r\n  --primary-700: #0b3880;\r\n  --primary-800: #08295e;\r\n  --primary-900: #051a3c;\r\n  --primary-950: #020c1c;\r\n\r\n  /* Semantic colour tokens (light) */\r\n  /* Blue-tinted gradient gives a soft light-source feel from above */\r\n  --color-bg:              linear-gradient(160deg, #f8fafc 0%, #f1f5f9 50%, #eef2f6 100%);\r\n  --color-bg-elevated:     #ffffff;\r\n  --color-bg-surface:      rgba(255, 255, 255, 0.7);\r\n  --color-bg-overlay:      rgba(0, 0, 0, 0.45);\r\n  --color-bg-input:        var(--neutral-50);\r\n\r\n  --color-fg:              var(--neutral-800);\r\n  --color-fg-primary:      var(--neutral-900);\r\n  --color-fg-secondary:    var(--neutral-600);\r\n  --color-fg-tertiary:     var(--neutral-500);\r\n  --color-fg-disabled:     var(--neutral-500);\r\n  --color-fg-inverse:      #ffffff;\r\n\r\n  --color-accent:          var(--primary-500);\r\n  --color-accent-hover:    var(--primary-600);\r\n  --color-accent-active:   var(--primary-700);\r\n  --color-accent-subtle:   var(--primary-100);\r\n  --color-accent-fg:       #ffffff;\r\n  --color-accent-hover-fg: #ffffff;\r\n  --color-accent-active-fg:#ffffff;\r\n  --color-accent-subtle-fg:var(--neutral-800);\r\n\r\n  --color-border:          rgba(16, 82, 188, 0.12);\r\n  --color-border-hover:    rgba(16, 82, 188, 0.22);\r\n  --color-border-strong:   rgba(16, 82, 188, 0.32);\r\n  --color-border-focus:    var(--primary-500);\r\n  --color-border-subtle:   rgba(16, 82, 188, 0.06);\r\n\r\n  --color-success:         #15803d;\r\n  --color-success-bg:      #f0fdf4;\r\n  --color-success-dim:     #86efac;\r\n  --color-warning:         #b45309;\r\n  --color-warning-bg:      #fffbeb;\r\n  --color-danger:          #dc2626;\r\n  --color-danger-hover:    #b91c1c;\r\n  --color-danger-700:      #991b1b;\r\n  --color-danger-bg:       #fef2f2;\r\n  --color-danger-dim:      #fecaca;\r\n  --color-danger-fg:       #ffffff;\r\n  --color-info:            #2563eb;\r\n  --color-info-bg:         #eff6ff;\r\n\r\n  --color-link:            var(--primary-600);\r\n  --color-link-hover:      var(--primary-700);\r\n  --color-link-visited:    #6d28d9;\r\n\r\n  --color-bg-primary:      #ffffff;\r\n  --color-bg-secondary:    var(--neutral-100);\r\n  --color-bg-hover:        rgba(16, 82, 188, 0.06);\r\n\r\n  --color-accent-dim:      rgba(16, 82, 188, 0.1);\r\n  --color-accent-alpha:    rgba(16, 82, 188, 0.18);\r\n  --color-accent-secondary: var(--primary-400);\r\n\r\n  /* Shadows — single size (8px), normal elevation curve */\r\n  --shadow-xs:   0 0 12px rgba(15,23,42,0.00);\r\n  --shadow-sm:   0 0 12px rgba(15,23,42,0.08);\r\n  --shadow-md:   0 0 12px rgba(15,23,42,0.16);\r\n  --shadow-lg:   0 0 12px rgba(15,23,42,0.24);\r\n  --shadow-xl:   0 0 12px rgba(15,23,42,0.32);\r\n  --shadow-2xl:  0 0 12px rgba(15,23,42,0.40);\r\n  --shadow-inner: inset 0 2px 4px rgba(15, 23, 42, 0.06);\r\n  /* Status-glow shadows */\r\n  --shadow-glow-success: 0 0 8px rgba(16, 185, 129, 0.4);\r\n  --shadow-glow-warning: 0 0 8px rgba(245, 158, 11, 0.4);\r\n  --shadow-glow-danger:  0 0 8px rgba(239, 68, 68, 0.4);\r\n}\r\n\r\n/* ── Dark mode (Steel Blue Solid) ──────────────── */\r\n[data-theme='dark'] {\r\n  --blur-amount: 0px;\r\n  --shadow-glow: none;\r\n\r\n  /* Neutral — steel blue tinted darks for cohesive depth */\r\n  --neutral-50:  #080e16;\r\n  --neutral-100: #0e1826;\r\n  --neutral-200: #152133;\r\n  --neutral-300: #1f3045;\r\n  --neutral-400: #2e4560;\r\n  --neutral-500: #4a6a8a;\r\n  --neutral-600: #7a9ec0;\r\n  --neutral-700: #a8c4de;\r\n  --neutral-800: #cddff0;\r\n  --neutral-900: #e8f1f9;\r\n  --neutral-950: #f5f9fd;\r\n\r\n  /* Brand / Primary — Steel Blue */\r\n  --primary-50:  #f0f5fa;\r\n  --primary-100: #dbeafe;\r\n  --primary-200: #bfdbfe;\r\n  --primary-300: #93c5fd;\r\n  --primary-400: #5a9fd4;\r\n  --primary-500: #2b5c8f;\r\n  --primary-600: #224b75;\r\n  --primary-700: #1a3a5c;\r\n  --primary-800: #122945;\r\n  --primary-900: #0b1a2e;\r\n  --primary-950: #060d17;\r\n\r\n  /* Semantic tokens (dark solid) */\r\n  --color-bg:              var(--neutral-50);\r\n  --color-bg-elevated:     var(--neutral-100);\r\n  --color-bg-surface:      var(--neutral-200);\r\n  --color-bg-overlay:      rgba(0, 0, 0, 0.55);\r\n  --color-bg-input:        var(--neutral-200);\r\n\r\n  --color-fg:              var(--neutral-800);\r\n  --color-fg-primary:      var(--neutral-900);\r\n  --color-fg-secondary:    var(--neutral-700);\r\n  --color-fg-tertiary:     var(--neutral-600);\r\n  --color-fg-disabled:     var(--neutral-600);\r\n  --color-fg-inverse:      #07111d;\r\n\r\n  /* Luminous accent for dark surfaces */\r\n  --color-accent:          #5a9fd4;\r\n  --color-accent-hover:    #73b2e0;\r\n  --color-accent-active:   #3d88c4;\r\n  --color-accent-subtle:   rgba(16, 82, 188, 0.2);\r\n  --color-accent-fg:       #07111d;\r\n  --color-accent-hover-fg: #07111d;\r\n  --color-accent-active-fg:#07111d;\r\n  --color-accent-subtle-fg:var(--neutral-800);\r\n\r\n  --color-border:          rgba(90, 159, 212, 0.12);\r\n  --color-border-hover:    rgba(90, 159, 212, 0.22);\r\n  --color-border-strong:   rgba(90, 159, 212, 0.32);\r\n  --color-border-focus:    #5a9fd4;\r\n  --color-border-subtle:   rgba(16, 82, 188, 0.08);\r\n\r\n  --color-success:         #4ade80;\r\n  --color-success-bg:      rgba(74, 222, 128, 0.08);\r\n  --color-warning:         #fbbf24;\r\n  --color-warning-bg:      rgba(251, 191, 36, 0.08);\r\n  --color-danger:          #dc2626;\r\n  --color-danger-hover:    #b91c1c;\r\n  --color-danger-bg:       rgba(220, 38, 38, 0.12);\r\n  --color-danger-fg:       #ffffff;\r\n  --color-info:            #60a5fa;\r\n  --color-info-bg:         rgba(96, 165, 250, 0.08);\r\n\r\n  --color-link:            #73b2e0;\r\n  --color-link-hover:      #93c5fd;\r\n  --color-link-visited:    #a78bfa;\r\n\r\n  --color-bg-primary:      var(--neutral-100);\r\n  --color-bg-secondary:    var(--neutral-200);\r\n  --color-bg-hover:        rgba(90, 159, 212, 0.08);\r\n\r\n  --color-accent-dim:      rgba(90, 159, 212, 0.12);\r\n  --color-accent-alpha:    rgba(90, 159, 212, 0.2);\r\n  --color-accent-secondary: #5a9fd4;\r\n\r\n  /* Shadows — single size (8px), normal elevation curve */\r\n  --shadow-xs:   0 0 12px rgba(8,14,22,0.00);\r\n  --shadow-sm:   0 0 12px rgba(8,14,22,0.08);\r\n  --shadow-md:   0 0 12px rgba(8,14,22,0.16);\r\n  --shadow-lg:   0 0 12px rgba(8,14,22,0.24);\r\n  --shadow-xl:   0 0 12px rgba(8,14,22,0.32);\r\n  --shadow-2xl:  0 0 12px rgba(8,14,22,0.40);\r\n  --shadow-inner: inset 0 2px 4px rgba(8, 14, 22, 0.25);\r\n  /* Status-glow shadows */\r\n  --shadow-glow-success: 0 0 8px rgba(16, 185, 129, 0.4);\r\n  --shadow-glow-warning: 0 0 8px rgba(245, 158, 11, 0.4);\r\n  --shadow-glow-danger:  0 0 8px rgba(239, 68, 68, 0.4);\r\n}\r\n\r\n/* ── Smooth theme transitions ──────────────────── */\r\nhtml.is-theme-transitioning *,\r\nhtml.is-theme-transitioning *::before,\r\nhtml.is-theme-transitioning *::after {\r\n  transition-property: color, background-color, border-color,\r\n    box-shadow, text-decoration-color, backdrop-filter !important;\r\n  transition-duration: var(--duration-200) !important;\r\n  transition-timing-function: var(--ease-out) !important;\r\n}\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n  *,\r\n  *::before,\r\n  *::after {\r\n    transition-duration: var(--duration-0) !important;\r\n    animation-duration: var(--duration-0) !important;\r\n  }\r\n}\r\n"],["STYLE",{},"/* ============================================================\r\n * OZ-POS Shared Component Styles\r\n *\r\n * Every class references design tokens via var(--token).\r\n * Never hardcode colours, sizes, or shadows.\r\n * ============================================================ */\r\n\r\n/* ── Button ─────────────────────────────────────────── */\r\n.btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--space-2);\r\n  padding: var(--space-2) var(--space-4);\r\n  border-radius: var(--radius-lg);\r\n  font-family: var(--font-sans);\r\n  font-weight: var(--font-weight-medium);\r\n  line-height: 1;\r\n  white-space: nowrap;\r\n  cursor: pointer;\r\n  user-select: none;\r\n  border: 1px solid transparent;\r\n  transition:\r\n    background-color var(--duration-150) var(--ease-out),\r\n    color var(--duration-150) var(--ease-out),\r\n    border-color var(--duration-150) var(--ease-out),\r\n    box-shadow var(--duration-150) var(--ease-out);\r\n}\r\n.btn:disabled {\r\n  opacity: 0.5;\r\n  cursor: not-allowed;\r\n  pointer-events: none;\r\n}\r\n.btn:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n}\r\n\r\n/* Sizes */\r\n.btn--sm {\r\n  padding: var(--space-1) var(--space-3);\r\n  font-size: var(--text-sm);\r\n  border-radius: var(--radius-md);\r\n}\r\n.btn--md {\r\n  padding: var(--space-2) var(--space-4);\r\n  font-size: var(--text-base);\r\n}\r\n.btn--lg {\r\n  padding: var(--space-3) var(--space-6);\r\n  font-size: var(--text-md);\r\n  border-radius: var(--radius-xl);\r\n}\r\n\r\n/* Variants */\r\n.btn--primary {\r\n  background: var(--color-accent);\r\n  color: var(--color-accent-fg);\r\n  border-color: var(--color-accent);\r\n}\r\n.btn--primary:hover:not(:disabled) {\r\n  background: var(--color-accent-hover);\r\n  border-color: var(--color-accent-hover);\r\n}\r\n.btn--primary:active:not(:disabled) {\r\n  background: var(--color-accent-active);\r\n}\r\n\r\n.btn--secondary {\r\n  background: transparent;\r\n  color: var(--color-fg);\r\n  border-color: var(--color-border);\r\n}\r\n.btn--secondary:hover:not(:disabled) {\r\n  background: var(--color-bg-surface);\r\n  border-color: var(--color-border-hover);\r\n}\r\n.btn--secondary:active:not(:disabled) {\r\n  background: var(--color-border);\r\n}\r\n\r\n.btn--danger {\r\n  background: var(--color-danger);\r\n  color: var(--color-danger-fg);\r\n  border-color: var(--color-danger);\r\n}\r\n.btn--danger:hover:not(:disabled) {\r\n  background: var(--color-danger-hover);\r\n  border-color: var(--color-danger-hover);\r\n}\r\n.btn--danger:active:not(:disabled) {\r\n  background: var(--color-danger-700);\r\n}\r\n\r\n.btn--ghost {\r\n  background: transparent;\r\n  color: var(--color-fg-secondary);\r\n  border-color: transparent;\r\n}\r\n.btn--ghost:hover:not(:disabled) {\r\n  background: var(--color-bg-surface);\r\n  color: var(--color-fg);\r\n}\r\n.btn--ghost:active:not(:disabled) {\r\n  background: var(--color-border);\r\n}\r\n\r\n/* Loading spinner */\r\n.btn__spinner {\r\n  width: 1em;\r\n  height: 1em;\r\n  border: 2px solid currentColor;\r\n  border-top-color: transparent;\r\n  border-radius: var(--radius-full);\r\n}\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  .btn__spinner {\r\n    animation: btn-spin var(--duration-600) var(--ease-linear) infinite;\r\n  }\r\n}\r\n\r\n@keyframes btn-spin {\r\n  to { transform: rotate(360deg); }\r\n}\r\n\r\n/* ── Navigation item ─────────────────────────────────── */\r\n.nav-item:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n}\r\n\r\n/* ── Tab ─────────────────────────────────────────────── */\r\n[role=\"tablist\"] [role=\"tab\"]:focus-visible {\r\n  outline: 2px solid var(--color-border-focus);\r\n  outline-offset: 2px;\r\n}\r\n\r\n/* ── Input ──────────────────────────────────────────── */\r\n.input-wrapper {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-1_5);\r\n}\r\n\r\n.input-label {\r\n  font-size: var(--text-sm);\r\n  font-weight: var(--font-weight-medium);\r\n  color: var(--color-fg-secondary);\r\n}\r\n\r\n.input-field {\r\n  font-family: var(--font-sans);\r\n  font-size: var(--text-base);\r\n  line-height: var(--leading-normal);\r\n  color: var(--color-fg);\r\n  background: var(--color-bg-input);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--space-2) var(--space-3);\r\n  width: 100%;\r\n  /* outline suppressed — focus ring provided by box-shadow on :focus-visible */\r\n  outline: none;\r\n  transition:\r\n    border-color var(--duration-150) var(--ease-out),\r\n    box-shadow var(--duration-150) var(--ease-out);\r\n}\r\n.input-field::placeholder {\r\n  color: var(--color-fg-tertiary);\r\n}\r\n.input-field:focus-visible {\r\n  outline: none;\r\n  border-color: var(--color-border-focus);\r\n  box-shadow: 0 0 0 3px var(--color-accent-subtle);\r\n}\r\n.input-field:disabled {\r\n  opacity: 0.5;\r\n  cursor: not-allowed;\r\n  background: var(--color-bg-surface);\r\n}\r\n.input-field[aria-invalid='true'] {\r\n  border-color: var(--color-danger);\r\n}\r\n.input-field[aria-invalid='true']:focus-visible {\r\n  box-shadow: 0 0 0 3px var(--color-danger-bg);\r\n}\r\n\r\n.input-helper {\r\n  font-size: var(--text-xs);\r\n  color: var(--color-fg-tertiary);\r\n}\r\n.input-error {\r\n  font-size: var(--text-xs);\r\n  color: var(--color-danger);\r\n}\r\n\r\n/* ── Card ───────────────────────────────────────────── */\r\n.card {\r\n  position: relative;\r\n  background: var(--color-bg-elevated);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-xl);\r\n  overflow: hidden;\r\n}\r\n\r\n/* ── Dithering noise overlay (P11) ──────────────────\r\n *\r\n * Breaks up 8-bit shadow/background banding on dark themes\r\n * using SVG feTurbulence at 10% opacity with larger grains.\r\n *\r\n * USAGE (recommended for NEW components):\r\n *   Add class=\"noise-dither\" to any elevated surface element\r\n *   (card, modal, dropdown, tooltip, etc.) that uses box-shadow.\r\n *   No CSS changes needed — just add the className.\r\n *\r\n * LEGACY selectors (feature-specific classes) are kept below\r\n * for backward compatibility. They are DEPRECATED — new\r\n * components should use `.noise-dither` instead.\r\n */\r\n\r\n/* Shared noise SVG data URI — stored as a CSS custom property */\r\n:root {\r\n  --noise-uri: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 64 64' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.25' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='64' height='64' filter='url(%23n)'/%3E%3C/svg%3E\");\r\n}\r\n\r\n/* Core pattern classes get noise automatically.\r\n   Feature-specific legacy selectors are grouped below. */\r\n.card::after,\r\n.modal-panel::after,\r\n.staff-login-card::after,\r\n.workspace-card::after,\r\n/* Reusable utility class — recommended for new components */\r\n.noise-dither::after,\r\n/* ⚠ DEPRECATED LEGACY SELECTORS — do not add new ones here.\r\n   Instead, add className=\"noise-dither\" to the TSX element. */\r\n.retail-shift-modal::after,\r\n.retail-held-carts-modal::after,\r\n.retail-discount-modal::after,\r\n.retail-qty-modal::after,\r\n.retail-shortcuts-modal::after,\r\n.retail-preview-modal::after,\r\n.retail-customer-modal::after,\r\n.tables-detail::after,\r\n.settings-popup::after,\r\n.license-activation-card::after,\r\n.gift-cards-modal::after,\r\n.promo-mgmt-modal::after,\r\n.product-mgmt-modal::after,\r\n.po-form-modal::after,\r\n.stock-transfers-modal::after,\r\n.shift-mgmt-modal::after,\r\n.payment-modal::after,\r\n.sales-history-modal::after,\r\n.price-override-modal::after,\r\n.dev-toolbar::after,\r\n.restaurant-hamburger-dropdown::after,\r\n.restaurant-context-menu::after,\r\n.settings-sidebar::after,\r\n.tooltip-content::after,\r\n.ssel-dropdown::after,\r\n.multi-store-stat-card::after,\r\n.product-card::after,\r\n.kiosk-product-card::after,\r\n.setup-preset-card::after,\r\n.setup-step-panel::after,\r\n.pos-cart-line::after,\r\n.pos-cart-tip-segment::after,\r\n.permission-denied-card::after,\r\n.tables-floorplan::after,\r\n.terminal-mgmt-toggle-thumb::after,\r\n.workspace-card--active::after,\r\n.workspace-skeleton-card::after,\r\n.ctx-menu::after,\r\n.status-indicator.online::after,\r\n.status-indicator.warning::after,\r\n.status-indicator.offline::after,\r\n.fastpin-card::after,\r\n.qris-container::after,\r\n.store-switcher-dropdown::after,\r\n.create-pin-card::after,\r\n.custom-context-menu::after,\r\n.session-lock-card::after,\r\n.cat-mgmt-icon-badge::after,\r\n.cat-mgmt-icon-btn--selected::after,\r\n.location-picker-dropdown::after,\r\n.inventory-shift-bar::after,\r\n.shift-status-active .status-indicator::after,\r\n.shift-btn-primary::after,\r\n.shift-btn-danger::after,\r\n.shift-summary-modal::after,\r\n.threshold-dialog::after,\r\n.reverse-btn::after,\r\n.kds-layout-popover::after,\r\n.kds-ticket--green::after,\r\n.kds-ticket-urgent-badge::after,\r\n.kds-settings-popover::after,\r\n.product-mgmt-alert-drawer::after,\r\n.promo-mgmt-table::after,\r\n.menu-eng-tooltip::after,\r\n.retail-menu::after,\r\n.pos-cart-undo-bar::after,\r\n.pos-cart-tip-segment[aria-pressed='true']::after,\r\n.modifier-modal::after,\r\n.pos-hold-modal::after,\r\n.pos-held-list-modal::after,\r\n.pos-close-shift-modal::after,\r\n.receipt-preview-paper::after,\r\n.refund-modal::after,\r\n.shortfall-modal::after,\r\n.settings-footer-shortcut kbd::after,\r\n.toggle-thumb::after,\r\n.topology-node::after,\r\n.node-selected::after {\r\n  content: '';\r\n  position: absolute;\r\n  inset: 0;\r\n  border-radius: inherit;\r\n  opacity: 0.10;\r\n  pointer-events: none;\r\n  z-index: -1;\r\n  background-image: var(--noise-uri);\r\n  background-repeat: repeat;\r\n  background-size: 64px 64px;\r\n  mix-blend-mode: overlay;\r\n}\r\n\r\n.noise-dither {\r\n  position: relative;\r\n}\r\n\r\n/* High contrast mode — hide noise overlay for clarity */\r\n@media (prefers-contrast: high) {\r\n  .card::after,\r\n  .modal-panel::after,\r\n  .staff-login-card::after,\r\n  .workspace-card::after,\r\n  .noise-dither::after,\r\n  .retail-shift-modal::after,\r\n  .retail-held-carts-modal::after,\r\n  .retail-discount-modal::after,\r\n  .retail-qty-modal::after,\r\n  .retail-shortcuts-modal::after,\r\n  .retail-preview-modal::after,\r\n  .retail-customer-modal::after,\r\n  .tables-detail::after,\r\n  .settings-popup::after,\r\n  .license-activation-card::after,\r\n  .gift-cards-modal::after,\r\n  .promo-mgmt-modal::after,\r\n  .product-mgmt-modal::after,\r\n  .po-form-modal::after,\r\n  .stock-transfers-modal::after,\r\n  .shift-mgmt-modal::after,\r\n  .payment-modal::after,\r\n  .sales-history-modal::after,\r\n  .price-override-modal::after,\r\n  .dev-toolbar::after,\r\n  .restaurant-hamburger-dropdown::after,\r\n  .restaurant-context-menu::after,\r\n  .settings-sidebar::after,\r\n  .tooltip-content::after,\r\n  .ssel-dropdown::after,\r\n  .multi-store-stat-card::after,\r\n  .product-card::after,\r\n  .kiosk-product-card::after,\r\n  .setup-preset-card::after,\r\n  .setup-step-panel::after,\r\n  .pos-cart-line::after,\r\n  .pos-cart-tip-segment::after,\r\n  .permission-denied-card::after,\r\n.table