il-customer-modal::after,\r\n  .tables-detail::after,\r\n  .settings-popup::after,\r\n  .license-activation-card::after,\r\n  .gift-cards-modal::after,\r\n  .promo-mgmt-modal::after,\r\n  .product-mgmt-modal::after,\r\n  .po-form-modal::after,\r\n  .stock-transfers-modal::after,\r\n  .shift-mgmt-modal::after,\r\n  .payment-modal::after,\r\n  .sales-history-modal::after,\r\n  .price-override-modal::after,\r\n  .dev-toolbar::after,\r\n  .restaurant-hamburger-dropdown::after,\r\n  .restaurant-context-menu::after,\r\n  .settings-sidebar::after,\r\n  .tooltip-content::after,\r\n  .ssel-dropdown::after,\r\n  .multi-store-stat-card::after,\r\n  .product-card::after,\r\n  .kiosk-product-card::after,\r\n  .setup-preset-card::after,\r\n  .setup-step-panel::after,\r\n  .pos-cart-line::after,\r\n  .pos-cart-tip-segment::after,\r\n  .permission-denied-card::after,\r\n.tables-floorplan::after,\r\n.terminal-mgmt-toggle-thumb::after,\r\n.workspace-card--active::after,\r\n.workspace-skeleton-card::after,\r\n.ctx-menu::after,\r\n.status-indicator.online::after,\r\n.status-indicator.warning::after,\r\n.status-indicator.offline::after,\r\n.fastpin-card::after,\r\n.qris-container::after,\r\n.store-switcher-dropdown::after,\r\n.create-pin-card::after,\r\n.custom-context-menu::after,\r\n.session-lock-card::after,\r\n.cat-mgmt-icon-badge::after,\r\n.cat-mgmt-icon-btn--selected::after,\r\n.location-picker-dropdown::after,\r\n.inventory-shift-bar::after,\r\n.shift-status-active .status-indicator::after,\r\n.shift-btn-primary::after,\r\n.shift-btn-danger::after,\r\n.shift-summary-modal::after,\r\n.threshold-dialog::after,\r\n.reverse-btn::after,\r\n.kds-layout-popover::after,\r\n.kds-ticket--green::after,\r\n.kds-ticket-urgent-badge::after,\r\n.kds-settings-popover::after,\r\n.product-mgmt-alert-drawer::after,\r\n.promo-mgmt-table::after,\r\n.menu-eng-tooltip::after,\r\n.retail-menu::after,\r\n.pos-cart-undo-bar::after,\r\n.pos-cart-tip-segment[aria-pressed='true']::after,\r\n.modifier-modal::after,\r\n.pos-hold-modal::after,\r\n.pos-held-list-modal::after,\r\n.pos-close-shift-modal::after,\r\n.receipt-preview-paper::after,\r\n.refund-modal::after,\r\n.shortfall-modal::after,\r\n.settings-footer-shortcut kbd::after,\r\n.toggle-thumb::after,\r\n.topology-node::after,\r\n.node-selected::after { display: none; }\r\n}\r\n\r\n.card--padding-sm  { padding: var(--space-3); }\r\n.card--padding-md  { padding: var(--space-5); }\r\n.card--padding-lg  { padding: var(--space-8); }\r\n\r\n.card--shadow-xs  { box-shadow: var(--shadow-xs); }\r\n.card--shadow-sm  { box-shadow: var(--shadow-sm); }\r\n.card--shadow-md  { box-shadow: var(--shadow-md); }\r\n.card--shadow-lg  { box-shadow: var(--shadow-lg); }\r\n\r\n.card-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  gap: var(--space-3);\r\n  padding-bottom: var(--space-4);\r\n  margin-bottom: var(--space-4);\r\n  border-bottom: 1px solid var(--color-border);\r\n}\r\n.card-header:empty {\r\n  display: none;\r\n}\r\n\r\n.card-body {\r\n  flex: 1;\r\n}\r\n\r\n.card-footer {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: flex-end;\r\n  gap: var(--space-3);\r\n  padding-top: var(--space-4);\r\n  margin-top: var(--space-4);\r\n  border-top: 1px solid var(--color-border);\r\n}\r\n.card-footer:empty {\r\n  display: none;\r\n}\r\n\r\n/* ── Modal ──────────────────────────────────────────── */\r\n.modal-overlay {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: var(--z-modal);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: rgba(0, 0, 0, 0.65);\r\n  backdrop-filter: blur(6px);\r\n  -webkit-backdrop-filter: blur(6px);\r\n  will-change: backdrop-filter;\r\n  transform: translateZ(0);\r\n  animation: modal-fade-in var(--duration-300) var(--ease-out);\r\n}\r\n\r\n@keyframes modal-fade-in {\r\n  from { opacity: 0; }\r\n  to   { opacity: 1; }\r\n}\r\n\r\n.modal-panel {\r\n  position: relative;\r\n  background: var(--color-bg);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-2xl);\r\n  box-shadow: var(--shadow-2xl);\r\n  width: 90%;\r\n  max-width: 560px;\r\n  max-height: 85vh;\r\n  display: flex;\r\n  flex-direction: column;\r\n  animation: modal-slide-up var(--duration-300) var(--ease-out);\r\n}\r\n\r\n.modal-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  gap: var(--space-3);\r\n  padding: var(--space-5) var(--space-6) 0;\r\n}\r\n\r\n.modal-title {\r\n  font-size: var(--text-lg);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--color-fg-primary);\r\n  margin: 0;\r\n}\r\n\r\n.modal-close-btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: var(--touch-target-min);\r\n  height: var(--touch-target-min);\r\n  border-radius: var(--radius-md);\r\n  color: var(--color-fg-secondary);\r\n  background: transparent;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: background-color var(--duration-150) var(--ease-out);\r\n}\r\n.modal-close-btn:hover {\r\n  background: var(--color-bg-surface);\r\n  color: var(--color-fg);\r\n}\r\n\r\n.modal-body {\r\n  padding: var(--space-5) var(--space-6);\r\n  overflow-y: auto;\r\n  flex: 1;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-4);\r\n}\r\n\r\n.modal-footer {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: flex-end;\r\n  gap: var(--space-3);\r\n  padding: var(--space-4) var(--space-6);\r\n  border-top: 1px solid var(--color-border);\r\n}\r\n\r\n.theme-toggle {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: auto;\r\n  height: auto;\r\n  background: transparent;\r\n  border: none;\r\n  cursor: pointer;\r\n  padding: 6px;\r\n  color: var(--color-fg-secondary);\r\n  transition: color var(--duration-150) var(--ease-out);\r\n}\r\n.theme-toggle:hover {\r\n  background: transparent;\r\n  color: var(--color-fg);\r\n}\r\n.theme-toggle svg {\r\n  transform-origin: center;\r\n  transition: transform var(--duration-200) var(--ease-in-out);\r\n}\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  .theme-toggle:hover svg {\r\n    animation: theme-wiggle var(--duration-500) var(--ease-in-out) infinite;\r\n  }\r\n}\r\n\r\n@keyframes theme-wiggle {\r\n  0%, 100% { transform: rotate(0deg); }\r\n  25% { transform: rotate(-12deg); }\r\n  75% { transform: rotate(12deg); }\r\n}\r\n\r\n@keyframes modal-slide-up {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateY(12px) scale(0.98);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateY(0) scale(1);\r\n  }\r\n}\r\n\r\n/* Reduced motion — disable animations only, preserve visual styling */\r\n@media (prefers-reduced-motion: reduce) {\r\n  .modal-overlay {\r\n    animation: none;\r\n  }\r\n  .modal-panel {\r\n    animation: none;\r\n  }\r\n}\r\n\r\n/* ── ConfirmDialog ─────────────────────────────────────── */\r\n.confirm-dialog-body {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  text-align: center;\r\n  gap: var(--space-2);\r\n  padding: var(--space-2) 0;\r\n}\r\n\r\n.confirm-dialog-icon {\r\n  width: 2.5rem;\r\n  height: 2.5rem;\r\n  border-radius: var(--radius-full);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.confirm-dialog-icon--danger {\r\n  background: var(--color-danger-bg, rgba(239, 68, 68, 0.12));\r\n  color: var(--color-danger, #ef4444);\r\n}\r\n\r\n.confirm-dialog-icon--warning {\r\n  background: var(--color-warning-bg, rgba(245, 158, 11, 0.12));\r\n  color: var(--color-warning, #f59e0b);\r\n}\r\n\r\n.confirm-dialog-icon--info {\r\n  background: var(--color-info-bg, rgba(59, 130, 246, 0.12));\r\n  color: var(--color-info, #3b82f6);\r\n}\r\n\r\n.confirm-dialog-icon svg {\r\n  width: 1.25rem;\r\n  height: 1.25rem;\r\n}\r\n\r\n.confirm-dialog-message {\r\n  font-size: var(--text-sm);\r\n  color: var(--color-fg-secondary);\r\n  line-height: var(--leading-relaxed);\r\n  margin: 0;\r\n  max-width: 22rem;\r\n}\r\n\r\n.confirm-dialog-actions {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: var(--space-2);\r\n  width: 100%;\r\n}\r\n\r\n/* ── Spinner ─────────────────────────────────────────── */\r\n.spinner {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: var(--space-2);\r\n}\r\n.spinner::before {\r\n  content: '';\r\n  display: inline-block;\r\n  border: 2px solid currentColor;\r\n  border-top-color: transparent;\r\n  border-radius: var(--radius-full);\r\n}\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  .spinner::before {\r\n    animation: spinner-rotate var(--duration-600) var(--ease-linear) infinite;\r\n  }\r\n}\r\n\r\n.spinner--sm::before {\r\n  width: 0.75em;\r\n  height: 0.75em;\r\n}\r\n.spinner--md::before {\r\n  width: 1em;\r\n  height: 1em;\r\n}\r\n.spinner--lg::before {\r\n  width: 1.5em;\r\n  height: 1.5em;\r\n  border-width: 3px;\r\n}\r\n.spinner__label {\r\n  font-size: var(--text-sm);\r\n  color: var(--color-fg-secondary);\r\n}\r\n@keyframes spinner-rotate {\r\n  to { transform: rotate(360deg); }\r\n}\r\n\r\n/* ── Badge ───────────────────────────────────────────── */\r\n.badge {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  font-weight: var(--font-weight-medium);\r\n  line-height: 1;\r\n  white-space: nowrap;\r\n  border-radius: var(--radius-full);\r\n}\r\n.badge--sm {\r\n  font-size: var(--text-xs);\r\n  padding: 2px var(--space-1_5);\r\n}\r\n.badge--md {\r\n  font-size: var(--text-sm);\r\n  padding: var(--space-0_5) var(--space-2);\r\n}\r\n.badge--default {\r\n  background: var(--color-bg-surface);\r\n  color: var(--color-fg-secondary);\r\n}\r\n.badge--success {\r\n  background: var(--color-success-bg);\r\n  color: var(--color-success);\r\n}\r\n.badge--warning {\r\n  background: var(--color-warning-bg);\r\n  color: var(--color-warning);\r\n}\r\n.badge--danger {\r\n  background: var(--color-danger-bg);\r\n  color: var(--color-danger);\r\n}\r\n.badge--info {\r\n  background: var(--color-info-bg);\r\n  color: var(--color-info);\r\n}\r\n\r\n/* ── Toast ───────────────────────────────────────────── */\r\n.toast-container {\r\n  position: fixed;\r\n  bottom: var(--space-6);\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  z-index: var(--z-toast);\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: var(--space-3);\r\n  width: min(90vw, 25rem);\r\n  pointer-events: none;\r\n}\r\n.toast {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-3);\r\n  width: 100%;\r\n  padding: var(--space-3) var(--space-4);\r\n  border-radius: var(--radius-lg);\r\n  background: var(--color-bg-elevated);\r\n  border: 1px solid var(--color-border);\r\n  box-shadow: var(--shadow-lg);\r\n  pointer-events: auto;\r\n}\r\n\r\n.toast__message {\r\n  flex: 1;\r\n  min-width: 0;\r\n  font-size: var(--text-sm);\r\n  line-height: var(--leading-normal);\r\n  color: var(--color-fg);\r\n  word-break: break-word;\r\n  overflow-wrap: anywhere;\r\n}\r\n.toast__dismiss {\r\n  flex-shrink: 0;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: var(--touch-target-min);\r\n  height: var(--touch-target-min);\r\n  margin-right: calc(-1 * var(--space-2));\r\n  margin-top: calc(-1 * var(--space-2));\r\n  margin-bottom: calc(-1 * var(--space-2));\r\n  border-radius: var(--radius-sm);\r\n  color: var(--color-fg-tertiary);\r\n  background: transparent;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: background-color var(--duration-150) var(--ease-out);\r\n}\r\n.toast__dismiss:hover {\r\n  background: var(--color-bg-surface);\r\n  color: var(--color-fg);\r\n}\r\n.toast--success { border-left: 3px solid var(--color-success); }\r\n.toast--error   { border-left: 3px solid var(--color-danger); }\r\n.toast--warning { border-left: 3px solid var(--color-warning); }\r\n.toast--info    { border-left: 3px solid var(--color-info); }\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  .toast {\r\n    animation: toast-slide-in var(--duration-200) var(--ease-out);\r\n  }\r\n  @keyframes toast-slide-in {\r\n    from {\r\n      opacity: 0;\r\n      transform: translateX(100%);\r\n    }\r\n    to {\r\n      opacity: 1;\r\n      transform: translateX(0);\r\n    }\r\n  }\r\n  @keyframes toast-slide-out {\r\n    from {\r\n      opacity: 1;\r\n      transform: translateX(0);\r\n    }\r\n    to {\r\n      opacity: 0;\r\n      transform: translateX(100%);\r\n    }\r\n  }\r\n  .toast--exiting {\r\n    animation: toast-slide-out var(--duration-200) var(--ease-out) both;\r\n    pointer-events: none;\r\n  }\r\n}\r\n\r\n/* ── Skeleton ────────────────────────────────────────── */\r\n.skeleton {\r\n  background: var(--color-bg-surface);\r\n  border-radius: var(--radius-md);\r\n}\r\n\r\n@media (prefers-reduced-motion: no-preference) {\r\n  .skeleton {\r\n    animation: skeleton-pulse var(--duration-1500) var(--ease-in-out) infinite;\r\n  }\r\n}\r\n\r\n.skeleton--text {\r\n  height: 0.75em;\r\n  border-radius: var(--radius-sm);\r\n}\r\n.skeleton--circle {\r\n  border-radius: var(--radius-full);\r\n}\r\n.skeleton--block {\r\n  height: 100px;\r\n}\r\n@keyframes skeleton-pulse {\r\n  0%, 100% { opacity: 0.4; }\r\n  50%      { opacity: 0.8; }\r\n}\r\n\r\n/* ── Empty State ─────────────────────────────────────── */\r\n.empty-state {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  text-align: center;\r\n  padding: var(--space-12) var(--space-6);\r\n}\r\n.empty-state__icon {\r\n  font-size: 2.5rem;\r\n  margin-bottom: var(--space-4);\r\n  color: var(--color-fg-tertiary);\r\n}\r\n.empty-state__title {\r\n  font-size: var(--text-lg);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--color-fg);\r\n  margin: 0 0 var(--space-2);\r\n}\r\n.empty-state__desc {\r\n  font-size: var(--text-base);\r\n  color: var(--color-fg-secondary);\r\n  margin: 0 0 var(--space-6);\r\n  max-width: 300px;\r\n}\r\n.empty-state__action {\r\n  margin-top: var(--space-2);\r\n}\r\n\r\n/* ── Touch-friendly sizing ─────────────────────────── */\r\n@media (pointer: coarse) {\r\n  button, a, [role=\"button\"], input, select, textarea,\r\n  [role=\"tab\"], [role=\"radio\"], [role=\"switch\"],\r\n  summary, label {\r\n    min-height: var(--touch-target-min);\r\n    min-width: var(--touch-target-min);\r\n  }\r\n  .btn, .card-clickable, .nav-item,\r\n  [role=\"tablist\"] [role=\"tab\"] {\r\n    min-height: var(--touch-target-comfortable);\r\n    min-width: var(--touch-target-comfortable);\r\n  }\r\n}\r\n\r\n/* ── Error State ─────────────────────────────────────── */\r\n.error-state {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  text-align: center;\r\n  padding: var(--space-12) var(--space-6);\r\n}\r\n.error-state__icon {\r\n  font-size: 2.5rem;\r\n  margin-bottom: var(--space-4);\r\n  color: var(--color-danger);\r\n}\r\n.error-state__title {\r\n  font-size: var(--text-lg);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--color-fg);\r\n  margin: 0 0 var(--space-2);\r\n}\r\n.error-state__message {\r\n  font-size: var(--text-base);\r\n  color: var(--color-fg-secondary);\r\n  margin: 0 0 var(--space-6);\r\n  max-width: 400px;\r\n}\r\n.error-state__action {\r\n  margin-top: var(--space-2);\r\n}\r\n\r\n/* Screen reader only utility (globally accessible) */\r\n.sr-only {\r\n  position: absolute;\r\n  width: 1px;\r\n  height: 1px;\r\n  padding: 0;\r\n  margin: -1px;\r\n  overflow: hidden;\r\n  clip: rect(0, 0, 0, 0);\r\n  white-space: nowrap;\r\n  border: 0;\r\n}\r\n"],["STYLE",{},"/* ── Responsive utility classes ──────────────────────────── */\r\n/* Hide on specific breakpoints */\r\n.hide-desktop { display: none; }\r\n.hide-tablet { display: revert; }\r\n.hide-mobile { display: revert; }\r\n\r\n@media (max-width: 1023px) {\r\n  .hide-tablet { display: none 