# ─────────────────────────────────────────────────────────────────────
# OZ-POS — Development Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
# Do NOT commit `.env` files — they contain secrets.
#
#   cp .env.example .env
#
# ── Database ────────────────────────────────────────────────────────
# Path to the local SQLite database file (oz-cli / desktop app).
# Default: oz-pos.db in the project root.
OZ_DB_PATH=oz-pos.db

# ── Tauri / Build ──────────────────────────────────────────────────
# Tauri updater signing key (keep this secret!).
#   cargo tauri signer generate -w oz-pos-updater.key
OZ_UPDATER_KEY_PATH=oz-pos-updater.key

# ── API Server (oz-api) ─────────────────────────────────────────────
# Host and port for the REST API server. Default: 127.0.0.1:8080
OZ_API_HOST=127.0.0.1
OZ_API_PORT=8080

# JWT signing secret for API tokens.
# Generate with: openssl rand -hex 32
OZ_JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Payment Gateways ────────────────────────────────────────────────
# Stripe secret key (sandbox/live). Sandbox keys start with sk_test_.
# Get yours at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Square access token (sandbox/live). Sandbox tokens start with EAAA.
# Get yours at https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=

# Midtrans / QRIS server key (sandbox/production).
# Get yours at https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=

# ── Cloud Sync ──────────────────────────────────────────────────────
# PostgreSQL connection string for direct DB-level sync.
# Format: postgres://user:password@host:5432/ozpos
OZ_CLOUD_DATABASE_URL=

# TLS certificate and key for secure cloud sync connections.
# Paths to PEM-encoded files.
OZ_TLS_CERT_PATH=
OZ_TLS_KEY_PATH=

# ── Exchange Rate Sync ───────────────────────────────────────────────
# API key for the exchange rate data provider.
# Frankfurter (free) doesn't need a key.
# Open Exchange Rates: https://openexchangerates.org
RATE_SYNC_API_KEY=

# ── Tauri Mobile ────────────────────────────────────────────────────
# Path to the Android SDK (for mobile builds).
# Example: C:\Users\Dika\AppData\Local\Android\Sdk
ANDROID_HOME=

# Path to the Android NDK.
# Example: C:\Users\Dika\AppData\Local\Android\Sdk\ndk\27.0.12077973
ANDROID_NDK_HOME=

# Path to JDK 17+ (Android build requirement).
# Android Studio bundles one: C:\Program Files\Android\Android Studio\jbr
JAVA_HOME=

# ── Logging ─────────────────────────────────────────────────────────
# Log level filter (trace, debug, info, warn, error). Default: info
RUST_LOG=info

# Optional: write logs to a file in addition to stdout.
OZ_LOG_FILE_PATH=
# OZ_LOG_FILE_PATH=logs/oz-pos.log

# ── Feature Flags ──────────────────────────────────────────────────
# Override features at startup (comma-separated kebab-case keys).
# Example: OZ_FEATURES=simple-retail,cash-payment,barcode-scanning
OZ_FEATURES=

# ── Security / PCI-DSS ─────────────────────────────────────────────
# PCI-DSS compliance mode (strict, lenient, off).
# When set to "strict", masked PAN display and audit logging are enforced.
OZ_PCI_MODE=strict
