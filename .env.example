# ── OZ-POS Development Environment ──────────────────────────────────
#
# Copy this file to `.env` and fill in the values.
# Do NOT commit `.env` files — they contain secrets.
#
#   cp .env.example .env
#
# ── Database ────────────────────────────────────────────────────────
# Path to the local SQLite database file.
# Default: oz-pos.db in the project root.
OZ_DB_PATH=oz-pos.db

# ── Tauri / Build ──────────────────────────────────────────────────
# Tauri updater signing key (keep this secret!)
#   cargo tauri signer generate -w oz-pos-updater.key
# Then paste the private key path or the key itself here.
OZ_UPDATER_KEY_PATH=oz-pos-updater.key

# ── API Server (oz-api) ─────────────────────────────────────────────
# Host and port for the REST API server.
# Default: 127.0.0.1:8080
OZ_API_HOST=127.0.0.1
OZ_API_PORT=8080

# JWT signing secret for API tokens.
# Generate with: openssl rand -hex 32
OZ_JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Cloud Sync ──────────────────────────────────────────────────────
# PostgreSQL connection string for cloud sync (if enabled).
# Format: postgres://user:password@host:5432/ozpos
OZ_CLOUD_DATABASE_URL=

# TLS certificate and key for secure cloud sync connections.
# Paths to PEM-encoded files.
OZ_TLS_CERT_PATH=
OZ_TLS_KEY_PATH=

# ── Payment Gateways ────────────────────────────────────────────────
# Stripe API keys (test mode for development).
# Get these from https://dashboard.stripe.com/test/apikeys
OZ_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
OZ_STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Square API keys (test mode).
OZ_SQUARE_APPLICATION_ID=
OZ_SQUARE_ACCESS_TOKEN=

# ── Logging ─────────────────────────────────────────────────────────
# Log level filter (trace, debug, info, warn, error).
# Default: info
RUST_LOG=info

# Optional: write logs to a file in addition to stdout.
# The file appender uses rotation (hourly, daily, or minutely).
OZ_LOG_FILE_PATH=
# OZ_LOG_FILE_PATH=logs/oz-pos.log

# ── Feature Flags ──────────────────────────────────────────────────
# Set to override features at startup (comma-separated kebab-case keys).
# Example: OZ_FEATURES=simple-retail,cash-payment,barcode-scanning
OZ_FEATURES=

# ── Security / PCI-DSS ─────────────────────────────────────────────
# PCI-DSS compliance mode (strict, lenient, off).
# When set to "strict", masked PAN display and audit logging are enforced.
OZ_PCI_MODE=strict
