# Build artifacts
/target/
/crates/*/target/
/apps/*/gen/
/apps/license-server/license-server.exe
/ui/playwright-report
/ui/test-results

# Cargo workspaces have a single Cargo.lock at the workspace root, not
# one per crate. OZ-POS ships binaries (oz-cli, and the Tauri app in
# src-tauri/) so the lockfile is committed for reproducible builds.
# Do NOT add a per-crate `Cargo.lock` line — they don't exist and the
# pattern would never match.

# Local state
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
.env
.env.local
.env.production
*.key
*.pem
secrets/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
# Windows reserved device name — git picks it up as untracked even though
# the file doesn't exist on disk. Keeping it ignored silences the noise.
nul

# Rust
**/*.rs.bk

# Coverage
/coverage/
/ui/coverage/

# Test artifacts
*.profraw
*.gcda
*.gcno

# Log files (runtime, test output, CI gates, etc.)
*.log
# Vitest profiling output (vitest --reporter=json)
/vitest-profile.json
# Skill drift guard report (generated by .agents/skills/skill-drift-guard/scripts/detect.sh)
/skill-drift-report.md

# Graph analysis artifacts (generated by graphify)
/graphify-out/
# Root-level scratch file
/temp.go

# Tauri — generated platform code (Android/iOS)
# Tauri requires real PNG/ICO icons; the scaffold ships without them.
# The generated icons are committed so CI and contributors don't need
# the Tauri CLI installed to build.
# apps/*/icons/*.png   ← committed, do not ignore
# apps/*/icons/*.ico   ← committed, do not ignore

# UI
/ui/node_modules/
/ui/.vite/
/ui/.eslintcache
/ui/.stylelintcache
ui/vite.config.js
ui/tsconfig.tsbuildinfo
ui/tsconfig.node.tsbuildinfo

# Root-level node deps & Vite cache (some tooling installs at root)
/node_modules/
/.vite/
