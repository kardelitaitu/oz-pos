# Build artifacts
/target/
/ui/dist/
/ui/node_modules/
/crates/*/target/

# Cargo workspaces have a single Cargo.lock at the workspace root, not
# one per crate. OZ-POS ships binaries (oz-cli, and the Tauri app in
# src-tauri/) so the lockfile is committed for reproducible builds.
# Do NOT add a per-crate `Cargo.lock` line — they don't exist and the
# pattern would never match.

# Local state
*.db
*.sqlite
*.sqlite3
.env
.env.local
.env.production
*.key
*.pem
secrets/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Rust
**/*.rs.bk

# Test artifacts
*.profraw
*.gcda
*.gcno

# Tauri
src-tauri/target/
src-tauri/gen/
# Tauri requires real PNG/ICO icons; the scaffold ships without them.
# Generate them with `cargo tauri icon path/to/source.png` once you
# have a source image. Until then `cargo build -p oz-pos-app` will
# fail at the resource-embedding step.
src-tauri/icons/*.png
src-tauri/icons/*.ico
src-tauri/icons/*.icns

# UI
/ui/dist/
/ui/node_modules/
/ui/coverage/
/ui/.vite/
/ui/.eslintcache
/ui/.stylelintcache
